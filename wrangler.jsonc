{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pythonbyexample",
  "main": "src/main.py",
  "compatibility_date": "2026-05-04",
  "compatibility_flags": [
    "python_workers",
    "python_dedicated_snapshot"
  ],
  "limits": {
    "cpu_ms": 60000
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ]
}
